# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# GLM API Configuration
GLM_API_KEY=your_glm_api_key
GLM_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
GLM_MODEL=glm-4.7
GLM_FALLBACK_MODEL=glm-4.5-air
# Comma-separated model ids allowed for your GLM account (recommended to customize).
GLM_MODELS=glm-4.7,glm-4.5-air,GLM-4.7,GLM-4.5-air
GLM_TIMEOUT_MS=90000
GLM_MAX_OUTPUT_TOKENS=900
RESUME_PIPELINE_V2=true
RESUME_PIPELINE_V2_SHADOW=false
RESUME_STRICT_NO_INVENT=true
RESUME_TARGET_MAX_CHARS=4200
GENERATION_MONTHLY_LIMIT=20

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Health endpoint protection (set in production)
HEALTHCHECK_SECRET=replace_with_a_long_random_secret
